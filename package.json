{
  "name": "coast-to-coast-kink",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "db:prepare": "node scripts/guard-not-production.mjs db:prepare && node scripts/wait-for-postgres.mjs && npm run db:push -w @c2k/api && npm run db:migrate-incremental -w @c2k/api && npm run db:seed -w @c2k/api && npm run db:ensure-preview-attendee-parity -w @c2k/api",
    "db:seed-moderation-ts-fixtures": "npm run db:seed-moderation-ts-fixtures -w @c2k/api",
    "db:migrate-prod": "node scripts/migrate-prod.mjs",
    "db:seed:reference": "npm run db:seed:reference -w @c2k/api",
    "db:seed:alpha:ecke": "npm run db:seed:alpha:ecke -w @c2k/api",
    "seed:alpha-social": "node scripts/seed-alpha-social.mjs",
    "db:clear:alpha:ecke": "npm run db:clear:alpha:ecke -w @c2k/api",
    "dev": "concurrently -n web,api -c blue,magenta \"npm run dev -w web\" \"npm run dev -w @c2k/api\"",
    "dev:web": "npm run dev -w web",
    "dev:api": "npm run dev -w @c2k/api",
    "build": "npm run build -w @c2k/shared && npm run build -w @c2k/api && npm run build -w web",
    "lint": "npm run lint -w web",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test e2e/route-smoke.desktop.spec.ts e2e/route-smoke.mobile.spec.ts e2e/auth.spec.ts",
    "test:e2e:alpha": "playwright test e2e/alpha-routes.spec.ts e2e/alpha-flows.spec.ts",
    "test:e2e:alpha-gate": "playwright test e2e/route-smoke.desktop.spec.ts e2e/route-smoke.mobile.spec.ts e2e/auth.spec.ts e2e/alpha-routes.spec.ts e2e/alpha-flows.spec.ts e2e/door.spec.ts e2e/moderation-ts.spec.ts",
    "capture:alpha-screenshots": "node scripts/capture-alpha-screenshots.mjs",
    "snapshot:alpha": "node scripts/emergency-alpha-audit.mjs",
    "visual:audit": "node scripts/visual-audit.mjs",
    "test:e2e:workflows": "playwright test e2e/auth.spec.ts e2e/organization.spec.ts e2e/event-create.spec.ts e2e/convention-dashboard.spec.ts e2e/door.spec.ts e2e/permissions.spec.ts e2e/exports-integrations.spec.ts",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install chromium",
    "audit:ui-inventory": "node scripts/audit-ui-inventory.mjs",
    "audit:ui-preflight": "node scripts/audit-ui-preflight.mjs",
    "audit:ui-architecture": "node scripts/audit-ui-architecture.mjs",
    "audit:ui-desktop": "node scripts/audit-ui-desktop-packet.mjs",
    "typecheck": "npm run typecheck -w @c2k/shared && npm run typecheck -w web && npm run typecheck -w @c2k/api",
    "storybook": "npm run storybook -w web",
    "build-storybook": "npm run build-storybook -w web",
    "check:dc-classes": "npm run check:dc-classes -w web",
    "test": "npm run test -w @c2k/api",
    "verify:prelaunch": "node scripts/verify-prelaunch.mjs",
    "verify:alpha-hardening-media": "node scripts/verify-alpha-hardening-media.mjs",
    "verify:alpha-hardening-operator": "node scripts/verify-alpha-hardening-operator.mjs",
    "verify:alpha-hardening-prod": "node scripts/smoke-alpha-hardening-prod.mjs",
    "verify:alpha-hardening-privacy": "node scripts/smoke-alpha-hardening-privacy.mjs",
    "verify:alpha-hardening-smtp-prod": "node scripts/smoke-alpha-hardening-smtp-prod.mjs",
    "verify:alpha-hardening-pilot-gate": "node scripts/smoke-alpha-hardening-pilot-gate.mjs",
    "remediate:vps:legacy-media": "node scripts/vps/run-alpha-hardening-media-remediation.mjs",
    "verify:alpha": "node scripts/verify-alpha-local.mjs",
    "verify:alpha:auto": "node scripts/verify-alpha-auto.mjs",
    "verify:alpha:auto:local": "node scripts/verify-alpha-auto-local.mjs",
    "verify:alpha:manual": "node scripts/verify-alpha-manual.mjs",
    "verify:trust-safety": "node scripts/verify-trust-safety-local.mjs",
    "verify:trust-safety:unit": "node scripts/verify-trust-safety.mjs",
    "verify:trust-safety:media": "node scripts/verify-trust-safety-media.mjs",
    "verify:trust-safety:admin-ui": "node scripts/verify-trust-safety-admin-ui.mjs",
    "verify:trust-safety:scanners": "node scripts/verify-trust-safety-scanners.mjs",
    "verify:trust-safety:media-policy": "node scripts/verify-trust-safety-media-policy.mjs",
    "verify:trust-safety:legal-profile": "node scripts/verify-trust-safety-legal-profile.mjs",
    "verify:trust-safety:dmca": "node scripts/verify-trust-safety-dmca.mjs",
    "verify:trust-safety:admin-security": "node scripts/verify-trust-safety-admin-security.mjs",
    "verify:trust-safety:privacy": "node scripts/verify-trust-safety-privacy.mjs",
    "handoff:context": "node scripts/generate-project-context-bundle.mjs --skip-verify",
    "db:ensure-brax-site-admin": "npm run db:ensure-brax-site-admin -w @c2k/api",
    "test:e2e:trust-safety": "playwright test e2e/moderation-ts.spec.ts",
    "test:e2e:trust-safety:media": "playwright test e2e/media-ts.spec.ts",
    "test:e2e:pass4": "playwright test e2e/ui-home-feed.spec.ts e2e/ui-home-feed.mobile.spec.ts e2e/ui-feed-reactions.spec.ts e2e/ui-menus-layering.spec.ts e2e/ui-directories.spec.ts e2e/ui-profile.spec.ts e2e/ui-privacy-api.spec.ts e2e/accessibility.spec.ts",
    "test:e2e:pass4:full": "npm run test:e2e:pass4 && playwright test e2e/smoke.spec.ts",
    "test:e2e:a11y": "playwright test e2e/accessibility.spec.ts",
    "smoke:domain-routing": "node scripts/vps/smoke-domain-routing.mjs",
    "verify:ecke-photo-bridge-contract": "node --import tsx/esm --test packages/shared/src/ecke-photos-manifest.test.ts packages/api/src/lib/ecke-photo-manifest.test.ts packages/api/src/lib/ecke-media-manifest-hash.test.ts",
    "verify:ecke-ingest-with-media": "node scripts/verify-ecke-ingest-with-media.mjs",
    "apply:ecke-photo-bridge-c2k": "node scripts/apply-ecke-photo-bridge-c2k.mjs"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.49.1",
    "concurrently": "^9.1.2",
    "drizzle-orm": "^0.40.0",
    "esbuild": "0.27.4",
    "ssh2": "^1.17.0",
    "typescript": "^5.9.2"
  },
  "engines": {
    "node": ">=18.x"
  },
  "overrides": {
    "esbuild": "0.27.4"
  }
}
