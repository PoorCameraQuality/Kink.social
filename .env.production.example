# =============================================================================
# C2K production environment template
# Copy to `.env.production` on the VPS (never commit real secrets).
# Used by: docker-compose.prod.yml (api + worker env_file), host migration runs.
# Web build-time vars (VITE_*) are passed as Docker build args — see DEPLOYMENT_RUNBOOK.md
# =============================================================================

# --- Runtime identity (required: api, worker) ---
# required | api, worker | example: production
NODE_ENV=production
# optional | all | explicit prod flag; also triggers production guards when set alone
# C2K_ENV=production

# --- Database (required: api, worker, migrations) ---
# required | api, worker | must be true or /api/v1/* returns 503
USE_DATABASE=true
# required | api, worker, migrate | postgres://user:pass@host:5432/dbname
DATABASE_URL=postgresql://c2k:CHANGE_ME@postgres:5432/c2k
# optional | api, worker | set true for managed Postgres (RDS, Supabase, Neon, etc.)
# DATABASE_SSL=true

# --- Redis / BullMQ (required: api, worker) ---
# required | api, worker | redis://redis:6379 or rediss://...
REDIS_URL=redis://redis:6379

# --- Auth / session (required: api) ---
# required | api | long random HMAC secret for c2k_session cookie — rotate if leaked
AUTH_SECRET=CHANGE_ME
# required | api | separate secret for @fastify/cookie signing
COOKIE_SECRET=CHANGE_ME
# required | api | MUST be false or unset in production (API refuses startup if true)
AUTH_ALLOW_FALLBACK=false
# optional | web build | mirror for Vite; API reads AUTH_ALLOW_FALLBACK at runtime
# VITE_AUTH_ALLOW_FALLBACK=false

# --- CORS (required when web and API are on different origins) ---
# required (split-origin) | api | comma-separated allowed origins, no trailing slash
# Same-origin Caddy deploy: set to https://yourdomain.com
CORS_ORIGIN=https://yourdomain.com

# --- Cookies (required: api behind HTTPS) ---
# optional | api | defaults to secure when NODE_ENV=production in auth routes
# COOKIE_SECURE=true
# optional | api | set when sharing cookies across subdomains (e.g. .yourdomain.com)
# COOKIE_DOMAIN=.yourdomain.com

# --- Public URLs (required: api, worker, web build) ---
# required | api, worker | canonical public web origin, no trailing slash
C2K_PUBLIC_WEB_URL=https://yourdomain.com
# optional | api | alias used in some ICS/link routes
# C2K_WEB_PUBLIC_URL=https://yourdomain.com
# required at web build | web | same as C2K_PUBLIC_WEB_URL for SEO/share links
# VITE_SITE_URL=https://yourdomain.com
# optional at web build | web | empty for same-origin (Caddy /api proxy); full URL if split API host
# VITE_API_URL=
# required (split-origin OAuth) | api | public API base, no trailing slash
API_PUBLIC_URL=https://yourdomain.com

# --- Domain / TLS (required: docker-compose.prod Caddy) ---
DOMAIN=yourdomain.com

# --- Object storage / uploads (required if uploads enabled) ---
# Production compose has NO MinIO — use external S3-compatible storage (AWS S3, Cloudflare R2, etc.).
# Local filesystem upload paths are NOT production-safe.
# required (uploads) | api | S3-compatible endpoint URL
S3_ENDPOINT=https://s3.us-east-1.amazonaws.com
# required (uploads) | api | bucket name
S3_BUCKET=c2k-uploads-prod
# optional | api | default us-east-1
S3_REGION=us-east-1
# required (uploads) | api | access key — never commit real values
S3_ACCESS_KEY=CHANGE_ME
# required (uploads) | api | secret key — never commit real values
S3_SECRET_KEY=CHANGE_ME
# optional | api | public CDN/base URL for browser-visible assets (no trailing slash)
# S3_PUBLIC_BASE_URL=https://cdn.yourdomain.com/c2k-uploads-prod

# --- Email (required for pilot transactional mail) ---
# required (pilot) | api, worker | smtp | resend | disabled (default disabled — no mail sent)
C2K_MAIL_TRANSPORT=smtp
C2K_MAIL_FROM=Kink.Social <noreply@yourdomain.com>
# optional | api | display name in email body/subject (From header uses C2K_MAIL_FROM)
# C2K_MAIL_PRODUCT_NAME=Kink.Social
# optional | api | override default password recovery / changed subjects
# C2K_PASSWORD_RESET_EMAIL_SUBJECT=Kink.Social password recovery
# C2K_PASSWORD_CHANGED_EMAIL_SUBJECT=Kink.Social password changed
C2K_MAIL_REPLY_TO=support@yourdomain.com
# VPS Docker network: SMTP_HOST=mailserver — external DNS: mail.yourdomain.com
SMTP_HOST=mail.yourdomain.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=
# Aliases for compose scripts (optional): C2K_SMTP_HOST, C2K_SMTP_USER, C2K_SMTP_PASS
C2K_PASSWORD_RESET_ENABLED=true
C2K_PUBLIC_WEB_URL=https://yourdomain.com
# Or Resend: C2K_MAIL_TRANSPORT=resend + RESEND_API_KEY=
# RESEND_API_KEY=
# DANGEROUS for adult platform — sensitive mail is never BCC'd; leave unset unless required
# C2K_PLATFORM_MAIL_BCC=admin@yourdomain.com
# optional | api | CSV export allowlist for email captures endpoint
# C2K_PLATFORM_ADMIN_EMAILS=admin@yourdomain.com
# optional | api, worker | transactional toggles
# C2K_ORG_JOIN_EMAIL=true
# C2K_EVENT_RSVP_EMAIL=true
# C2K_ACCOUNT_WELCOME_EMAIL=true
# C2K_SCOPE_EMAIL_DOUBLE_OPTIN=true

# --- Mail intake (optional IMAP import to admin dashboard) ---
# C2K_MAIL_INTAKE_ENABLED=false
# C2K_MAIL_INTAKE_IMAP_HOST=mailserver
# C2K_MAIL_INTAKE_IMAP_PORT=993
# C2K_MAIL_INTAKE_IMAP_SECURE=true
# C2K_MAIL_INTAKE_REPEAT_MS=300000
# C2K_MAIL_INTAKE_SUPPORT_USER=support@yourdomain.com
# C2K_MAIL_INTAKE_SUPPORT_PASS=
# C2K_MAIL_INTAKE_LEGAL_USER=legal@yourdomain.com
# C2K_MAIL_INTAKE_LEGAL_PASS=
# C2K_MAIL_INTAKE_BUSINESS_USER=business@yourdomain.com
# C2K_MAIL_INTAKE_BUSINESS_PASS=
# C2K_MAIL_INTAKE_ABUSE_USER=abuse@yourdomain.com
# C2K_MAIL_INTAKE_ABUSE_PASS=
# C2K_MAIL_INTAKE_SECURITY_USER=security@yourdomain.com
# C2K_MAIL_INTAKE_SECURITY_PASS=

# --- Webmail (Roundcube on VPS — Caddy hostname) ---
# ROUNDCUBE_HOST=webmail.yourdomain.com

# --- Web push (optional: api + worker) ---
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@yourdomain.com
# C2K_PUSH_ANNOUNCEMENTS=true
# C2K_PUSH_CHAT=true

# --- WebSockets / scaling (optional: api) ---
# required when running 2+ API replicas — see docs/REALTIME_SCALING.md
# C2K_REALTIME_REDIS_BRIDGE=true

# --- Rate limiting / pilot hardening (optional) ---
# C2K_RATE_LIMIT_DISABLE=false
# Controlled alpha: set invite code and/or close open registration
# C2K_REGISTRATION_INVITE_CODE=your-test-invite-code
# C2K_REGISTRATION_OPEN=false

# --- Controlled alpha upload disables (server-side 403 when true) ---
# Profile photos stay enabled when C2K_ALPHA_DISABLE_PROFILE_PHOTO_UPLOADS is unset/false
# C2K_ALPHA_DISABLE_ORG_BANNER_UPLOADS=true
# C2K_ALPHA_DISABLE_FEED_IMAGE_UPLOADS=true
# C2K_ALPHA_DISABLE_EVENT_COVER_UPLOADS=true
# C2K_ALPHA_DISABLE_CONVENTION_GALLERY_UPLOADS=true
# C2K_ALPHA_DISABLE_EDUCATION_HERO_UPLOADS=true
# C2K_ALPHA_DISABLE_PROFILE_PHOTO_UPLOADS=false

# --- Field-level encryption (required: api, worker in production) ---
# AES-256-GCM master key for reversible PII (user email ciphertext). Rotate with C2K_FIELD_ENCRYPTION_KEY_VERSION.
C2K_FIELD_ENCRYPTION_KEY=CHANGE_ME
# optional | api | increment when rotating encryption key (default 1)
# C2K_FIELD_ENCRYPTION_KEY_VERSION=1
# HMAC pepper for email lookup hashes — separate from encryption key
EMAIL_LOOKUP_PEPPER=CHANGE_ME

# --- Backup encryption (operator host, not API runtime) ---
# age public key for scripts/backup-postgres.sh off-server dumps
# BACKUP_ENCRYPTION_PUBLIC_KEY=age1...

# --- Retention job tuning (optional) ---
# C2K_RETENTION_DISABLE_REPEAT=false
# C2K_RETENTION_REPEAT_MS=86400000
# PASSWORD_RESET_TOKEN_PURGE_MS=86400000
# QUARANTINE_STALE_MS=604800000

# --- Reverse proxy / client IP (default trust proxy on) ---
# C2K_TRUST_PROXY=true

# --- Web build-time flags (set as Docker build args, not runtime env_file) ---
# VITE_HOME_DEMO_FALLBACK=false
# VITE_LEGAL_PUBLISHED=true

# --- Platform staff (optional: api) — required for moderation/admin without seed ---
# C2K_SITE_OWNER_USER_IDS=          # ONLY this UUID may break-glass reveal email/IP
# C2K_SITE_ADMIN_USER_IDS=
# C2K_PLATFORM_MODERATOR_USER_IDS=
# C2K_PLATFORM_ADMIN_EMAILS=owner@yourdomain.com

# --- Vendor integrations (optional: api) ---
# Encrypt WooCommerce keys + Shopify OAuth tokens at rest
EXTERNAL_STORE_SECRET=CHANGE_ME
# SHOPIFY_API_KEY=
# SHOPIFY_API_SECRET=
# ETSY_KEYSTRING=

# --- ECKE outbound publish (optional: api + worker) — keep disabled until ECKE ready ---
# ECKE_PUBLISH_ENABLED=false
# ECKE_SUPABASE_URL=https://YOUR-ECKE-PROJECT.supabase.co
# ECKE_SUPABASE_SERVICE_ROLE_KEY=
# ECKE_PUBLISH_LISTING_WEBHOOK_URL=
# ECKE_PUBLISH_WEBHOOK_SECRET=
# NEVER set in production — dev-only inline publish:
# C2K_ECKE_PUBLISH_INLINE=true

# --- LiveKit voice (optional: api) ---
# LIVEKIT_URL=wss://livekit.yourdomain.com
# LIVEKIT_API_KEY=
# LIVEKIT_API_SECRET=
# LIVEKIT_ROOM_PREFIX=c2k

# --- Product flags (optional) ---
# When true, org/event star reviews also bump global profile trustScore (legacy MVP).
ORG_REVIEW_PROPAGATES_GLOBAL_TRUST=false

# --- Postgres container (docker-compose.prod only — not api env) ---
POSTGRES_USER=c2k
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=c2k

# =============================================================================
# DO NOT RUN IN PRODUCTION (guarded — see docs/DEPLOYMENT_RUNBOOK.md):
#   npm run db:prepare     — dev only (push + seed; blocked in production)
#   npm run db:seed        — wipes + seeds; requires C2K_ALLOW_DESTRUCTIVE_DB_RESET=true in prod
#   npm run db:wipe        — truncates all tables; same override required
# Production schema updates: npm run db:migrate-prod (no seed)
# =============================================================================
