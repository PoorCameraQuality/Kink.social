{
  "version": 1,
  "description": "Routes for Playwright visual audit. Paths may use {placeholder} tokens resolved at runtime (see docs/VISUAL_AUDIT.md).",
  "placeholders": {
    "orgSlug": { "env": "VISUAL_AUDIT_ORG_SLUG", "default": "demo-east-collective" },
    "convSlug": { "env": "VISUAL_AUDIT_CONV_SLUG", "default": "preview-c2k-weekend" },
    "vendorSlug": { "env": "VISUAL_AUDIT_VENDOR_SLUG", "default": "rope-dreamer-supply" },
    "presenterUsername": { "env": "VISUAL_AUDIT_PRESENTER_USERNAME", "default": "LeatherCraftDemo" },
    "eventId": { "env": "VISUAL_AUDIT_EVENT_ID", "resolve": "event" },
    "groupId": { "env": "VISUAL_AUDIT_GROUP_ID", "resolve": "group" },
    "moderationCaseId": { "env": "VISUAL_AUDIT_MOD_CASE_ID", "resolve": "moderationCase" }
  },
  "routes": [
    { "id": "public-landing", "path": "/", "category": "public", "authRole": null },
    { "id": "public-join", "path": "/join", "category": "public", "authRole": null, "notes": "Redirects to /#join signup anchor" },
    { "id": "public-login", "path": "/?login=1", "category": "public", "authRole": null },
    { "id": "public-about", "path": "/about", "category": "public", "authRole": null },
    { "id": "public-safety", "path": "/support", "category": "public", "authRole": null, "notes": "Safety/support hub (no /safety route)" },
    { "id": "public-safety-alias", "path": "/safety", "category": "public", "authRole": null, "notes": "Redirects to /support" },
    { "id": "public-guidelines", "path": "/guidelines", "category": "public", "authRole": null },
    { "id": "public-community-guidelines", "path": "/community-guidelines", "category": "public", "authRole": null, "notes": "Redirects to /guidelines" },
    { "id": "public-privacy", "path": "/privacy", "category": "public", "authRole": null },
    { "id": "public-terms", "path": "/terms", "category": "public", "authRole": null },
    { "id": "public-contact", "path": "/contact", "category": "public", "authRole": null },
    { "id": "public-robots", "path": "/robots.txt", "category": "public", "authRole": null, "contentType": "text" },
    { "id": "public-security-txt", "path": "/.well-known/security.txt", "category": "public", "authRole": null, "contentType": "text" },
    { "id": "public-security-policy", "path": "/security", "category": "public", "authRole": null },
    { "id": "public-csaf-metadata", "path": "/.well-known/csaf/provider-metadata.json", "category": "public", "authRole": null, "contentType": "json" },
    { "id": "public-sitemap", "path": "/sitemap.xml", "category": "public", "authRole": null, "optional": true },

    { "id": "auth-home", "path": "/home", "category": "auth", "authRole": "member" },
    { "id": "auth-explore", "path": "/explore", "category": "auth", "authRole": "member" },
    { "id": "auth-events", "path": "/events", "category": "auth", "authRole": "member" },
    { "id": "auth-conventions", "path": "/conventions", "category": "auth", "authRole": "member" },
    { "id": "auth-groups", "path": "/groups", "category": "auth", "authRole": "member" },
    { "id": "auth-people", "path": "/people", "category": "auth", "authRole": "member" },
    { "id": "auth-organizations", "path": "/orgs", "category": "auth", "authRole": "member", "notes": "Canonical org directory (/organizations may 404)" },
    { "id": "auth-organizations-alias", "path": "/organizations", "category": "auth", "authRole": "member", "optional": true },
    { "id": "auth-vendors", "path": "/vendors", "category": "auth", "authRole": "member" },
    { "id": "auth-presenters", "path": "/presenters", "category": "auth", "authRole": "member" },
    { "id": "auth-education", "path": "/education", "category": "auth", "authRole": "member" },
    { "id": "auth-messages", "path": "/messaging", "category": "auth", "authRole": "member", "notes": "No ?c= thread — inbox shell only" },
    { "id": "auth-messages-alias", "path": "/messages", "category": "auth", "authRole": "member", "optional": true },
    { "id": "auth-notifications", "path": "/notifications", "category": "auth", "authRole": "member" },
    { "id": "auth-settings", "path": "/settings", "category": "auth", "authRole": "member" },
    { "id": "auth-settings-account", "path": "/settings/account", "category": "auth", "authRole": "member" },
    { "id": "auth-settings-privacy", "path": "/settings/privacy", "category": "auth", "authRole": "member" },
    { "id": "auth-settings-trust", "path": "/settings/trust", "category": "auth", "authRole": "member" },
    { "id": "auth-settings-ecosystem", "path": "/settings/ecosystem", "category": "auth", "authRole": "member" },

    { "id": "onboarding-member", "path": "/onboarding", "category": "onboarding", "authRole": "onboarding_member" },
    { "id": "onboarding-profile", "path": "/profile/edit?onboarding=1", "category": "onboarding", "authRole": "onboarding_member" },
    { "id": "onboarding-vendor", "path": "/vendors/onboarding", "category": "onboarding", "authRole": "onboarding_member" },
    { "id": "onboarding-presenter", "path": "/presenters/onboarding", "category": "onboarding", "authRole": "onboarding_member" },
    { "id": "onboarding-presenter-educator", "path": "/presenters/onboarding?track=educator", "category": "onboarding", "authRole": "onboarding_member" },
    { "id": "onboarding-presenter-speaker", "path": "/presenters/onboarding?track=speaker", "category": "onboarding", "authRole": "onboarding_member" },
    { "id": "onboarding-presenter-author", "path": "/presenters/onboarding?track=author", "category": "onboarding", "authRole": "onboarding_member" },
    { "id": "onboarding-presenter-photographer", "path": "/presenters/onboarding?track=photographer", "category": "onboarding", "authRole": "onboarding_member" },

    { "id": "vendor-directory", "path": "/vendors", "category": "vendor", "authRole": "member" },
    { "id": "vendor-profile", "path": "/vendors/{vendorSlug}", "category": "vendor", "authRole": "member" },
    { "id": "vendor-settings", "path": "/settings/vendor", "category": "vendor", "authRole": "vendor", "optional": true },
    { "id": "vendor-onboarding", "path": "/vendors/onboarding", "category": "vendor", "authRole": "vendor", "optional": true },

    { "id": "presenter-directory", "path": "/presenters", "category": "presenter", "authRole": "member" },
    { "id": "presenter-profile", "path": "/presenters/{presenterUsername}", "category": "presenter", "authRole": "member" },
    { "id": "presenter-ecosystem", "path": "/settings/ecosystem", "category": "presenter", "authRole": "presenter", "optional": true },

    { "id": "group-directory", "path": "/groups", "category": "group", "authRole": "member" },
    { "id": "group-detail", "path": "/groups/{groupId}", "category": "group", "authRole": "member", "optional": true },
    { "id": "group-organizer", "path": "/organizer/groups/{groupId}", "category": "group", "authRole": "org_owner", "optional": true },
    { "id": "group-organizer-settings", "path": "/organizer/groups/{groupId}?tab=settings", "category": "group", "authRole": "org_owner", "optional": true },

    { "id": "org-directory", "path": "/orgs", "category": "organization", "authRole": "member" },
    { "id": "org-profile", "path": "/orgs/{orgSlug}", "category": "organization", "authRole": "member" },
    { "id": "org-create", "path": "/orgs/new", "category": "organization", "authRole": "member" },
    { "id": "org-organizer-dashboard", "path": "/organizer/orgs/{orgSlug}", "category": "organization", "authRole": "org_owner", "optional": true },
    { "id": "org-organizer-settings", "path": "/organizer/orgs/{orgSlug}?tab=settings", "category": "organization", "authRole": "org_owner", "optional": true },

    { "id": "event-directory", "path": "/events", "category": "event", "authRole": "member" },
    { "id": "event-detail", "path": "/events/{eventId}", "category": "event", "authRole": "member", "optional": true },
    { "id": "event-host-list", "path": "/events?host=me", "category": "event", "authRole": "member", "optional": true },
    { "id": "event-organizer", "path": "/organizer/orgs/{orgSlug}/events/{eventId}", "category": "event", "authRole": "org_owner", "optional": true },

    { "id": "convention-directory", "path": "/conventions", "category": "convention", "authRole": "member" },
    { "id": "convention-hub", "path": "/conventions/{convSlug}", "category": "convention", "authRole": "member" },
    { "id": "convention-schedule", "path": "/conventions/{convSlug}?tab=Schedule", "category": "convention", "authRole": "member" },
    { "id": "convention-welcome", "path": "/conventions/{convSlug}?tab=Welcome", "category": "convention", "authRole": "member" },
    { "id": "convention-present-apply", "path": "/conventions/{convSlug}/present/apply", "category": "convention", "authRole": "member", "optional": true },
    { "id": "convention-organizer-dashboard", "path": "/organizer/orgs/{orgSlug}/conventions/{convSlug}?tab=dashboard", "category": "convention", "authRole": "org_owner", "optional": true },
    { "id": "convention-organizer-people", "path": "/organizer/orgs/{orgSlug}/conventions/{convSlug}?tab=people", "category": "convention", "authRole": "org_owner", "optional": true },

    { "id": "trust-settings", "path": "/settings/trust", "category": "trust", "authRole": "member" },
    { "id": "trust-support", "path": "/support", "category": "trust", "authRole": "member" },

    { "id": "moderation-dashboard", "path": "/moderation/dashboard", "category": "moderation", "authRole": "admin", "optional": true },
    { "id": "moderation-queues", "path": "/moderation/queues", "category": "moderation", "authRole": "admin", "optional": true },
    { "id": "moderation-cases", "path": "/moderation/cases", "category": "moderation", "authRole": "admin", "optional": true },
    { "id": "moderation-case-detail", "path": "/moderation/cases/{moderationCaseId}", "category": "moderation", "authRole": "admin", "optional": true },
    { "id": "moderation-reports", "path": "/moderation/reports", "category": "moderation", "authRole": "admin", "optional": true },
    { "id": "moderation-admin", "path": "/moderation/admin", "category": "moderation", "authRole": "admin", "optional": true }
  ]
}
