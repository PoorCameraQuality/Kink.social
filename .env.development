# Committed defaults — no secrets. Copy to .env locally if you override.
# DB-backed API + UI integration paths expect Postgres (see npm run db:prepare).
USE_DATABASE=true
# sslmode=disable avoids hangs when clients try TLS against non-TLS local Postgres (common on Windows + Docker).
DATABASE_URL=postgresql://c2k:c2k_dev@127.0.0.1:6432/c2k_dev?sslmode=disable
REDIS_URL=redis://127.0.0.1:6379
S3_ENDPOINT=http://127.0.0.1:9000
S3_BUCKET=c2k-uploads
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
VITE_API_URL=http://127.0.0.1:3001
VITE_SITE_URL=http://127.0.0.1:5173

# Site admin + mod team — re-run db:seed to refresh UUIDs if DB was wiped (also in platform_staff table)
# Brax = SITE_ADMIN; RopeDreamer = MODERATOR after seed (see seed output for current UUIDs)
C2K_SITE_ADMIN_USER_IDS=6cdfd84e-4203-48ee-b2e3-63a60ddad709
C2K_PLATFORM_MODERATOR_USER_IDS=6cdfd84e-4203-48ee-b2e3-63a60ddad709,05208e16-83e7-4d6b-851c-24694157e798
C2K_PLATFORM_ADMIN_EMAILS=brax@coast2coast.kink

# Mail — local Mailpit (docker compose -f docker-compose.dev.yml up -d mailpit)
# Web UI: http://127.0.0.1:8025  SMTP: 127.0.0.1:1025
C2K_MAIL_TRANSPORT=smtp
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_SECURE=false
C2K_MAIL_FROM=Kink.Social Dev <dev@localhost>
C2K_MAIL_REPLY_TO=support@kink.social
C2K_PUBLIC_WEB_URL=http://127.0.0.1:5173
# Transactional toggles (require C2K_MAIL_TRANSPORT=smtp and Mailpit or real SMTP)
C2K_ORG_JOIN_EMAIL=true
C2K_EVENT_RSVP_EMAIL=true
C2K_ACCOUNT_WELCOME_EMAIL=true
C2K_SCOPE_EMAIL_DOUBLE_OPTIN=true

# Web Push (generate: npx web-push generate-vapid-keys — then paste below)
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:dev@localhost

# BCC site owner on every outbound email (org/group broadcasts, RSVP, digests)
# C2K_PLATFORM_MAIL_BCC=you@yourdomain.com

# Local smokes/e2e — disable auth rate limits (Tier 1 plan: ok for dev only)
C2K_RATE_LIMIT_DISABLE=true
# Comma-separated emails allowed to export platform marketing captures
# C2K_PLATFORM_ADMIN_EMAILS=you@yourdomain.com

# Optional — Etsy Open API v3 (keystring only; see docs/FEATURE_REGISTRY.md)
# ETSY_KEYSTRING=
# ETSY_SYNC_DISABLE_REPEAT=true
# ETSY_SYNC_REPEAT_MS=2700000

# External storefronts (Woo secrets + Shopify tokens encrypted when set)
# EXTERNAL_STORE_SECRET=  # long random string in production
# API_PUBLIC_URL=http://127.0.0.1:3001
# SHOPIFY_API_KEY=
# SHOPIFY_API_SECRET=
# SHOPIFY_SCOPES=read_products
# EXTERNAL_SYNC_DISABLE_REPEAT=true
# EXTERNAL_SYNC_REPEAT_MS=2700000
