# Phase C — demo session API (see docs/PHASE_C.md)
# Copy to `.env.local` and adjust. Next.js loads `.env.local` automatically.

# Required in production: HMAC secret for signed `c2k_session` cookie.
# Development defaults to an insecure placeholder if unset (do not ship that).
AUTH_SECRET=

# ECKE outbound bridge — copy to `.env.local` (gitignored); never commit service role key
# ECKE_PUBLISH_ENABLED=true
# Option A (education_article ingest API — Pass 3B):
# Production only — do not point at Vercel preview URLs (*.vercel.app).
# ECKE_PUBLISH_ENDPOINT=https://www.eastcoastkinkevents.com/api/kink-social/ingest
# ECKE_UNPUBLISH_ENDPOINT=https://www.eastcoastkinkevents.com/api/kink-social/unpublish
# ECKE_PUBLISH_SECRET=
# ECKE_PUBLIC_BASE_URL=https://www.eastcoastkinkevents.com
# ECKE_PUBLISH_ALLOW_NON_PRODUCTION=true  # local dev only — never on VPS/production
# Option B (legacy vendor/convention/dungeon Supabase REST — still used for non-article entities):
# ECKE_SUPABASE_URL=https://YOUR-ECKE-PROJECT.supabase.co
# ECKE_SUPABASE_SERVICE_ROLE_KEY=
# ECKE_LISTING_ENDPOINT=https://www.eastcoastkinkevents.com/api/kink-social/listing
# Per-entity ingest cutover (Phase 1+ — disabled in Phase 0):
# ECKE_EVENT_INGEST_ENABLED=false
# ECKE_PLACE_INGEST_ENABLED=false
# ECKE_VENDOR_INGEST_ENABLED=false

# When not "false", unauthenticated GET /api/auth/session returns the mock viewer username (UX continuity).
# Set to false for strict mode: empty viewer until login + middleware redirects unauthenticated users
# to /?redirect=...&login=1 (see docs/PHASE_C.md).
NEXT_PUBLIC_AUTH_ALLOW_FALLBACK=

# Vite web app (packages/web) — also set in `.env.local` / deploy env
# VITE_API_URL=http://127.0.0.1:3001
# VITE_SITE_URL=http://127.0.0.1:5173
# VITE_HOME_DEMO_FALLBACK=false
# VITE_LEGAL_PUBLISHED=true

# --- Alpha ops observability (Pass 1 — disabled by default) ---
# See docs/ALPHA_OBSERVABILITY.md
# ERROR_TRACKING_ENABLED=false
# ERROR_TRACKING_DSN=
# SENTRY_DSN=                         # alias for ERROR_TRACKING_DSN
# ERROR_TRACKING_ENVIRONMENT=development
# RELEASE_VERSION=
# ERROR_TRACKING_TRACES_SAMPLE_RATE=0
# ERROR_TRACKING_TEST_ENABLED=false
# ERROR_TRACKING_TEST_SECRET=
# WORKER_HEARTBEAT_ENABLED=false
# HEALTH_STRICT_READINESS=false
# VITE_ERROR_TRACKING_ENABLED=false
# VITE_ERROR_TRACKING_DSN=
# VITE_SENTRY_DSN=
# VITE_ERROR_TRACKING_ENVIRONMENT=development
# VITE_RELEASE_VERSION=
# VITE_ERROR_TRACKING_TRACES_SAMPLE_RATE=0

# --- Sitewide search / Typesense (Pass 2B — disabled by default) ---
# See docs/SEARCH_TYPESENSE.md
# SEARCH_PROVIDER=database
# SEARCH_INDEXING_ENABLED=false
# SEARCH_QUERY_ENABLED=false
# SEARCH_ADMIN_REINDEX_ENABLED=false
# SEARCH_HOST=http://127.0.0.1:8108
# SEARCH_API_KEY=
# SEARCH_READ_API_KEY=
# SEARCH_INDEX_PREFIX=c2k
# SEARCH_ENVIRONMENT=development
# SEARCH_SYNC_BATCH_SIZE=100
# C2K_SEARCH_SYNC_INLINE=false

# --- imgproxy image delivery (Pass 3A — disabled by default) ---
# See docs/MEDIA_IMAGE_PROXY.md
# IMGPROXY_ENABLED=false
# IMGPROXY_BASE_URL=http://127.0.0.1:8080
# IMGPROXY_KEY=
# IMGPROXY_SALT=
# IMGPROXY_USE_HTTPS=true
# IMGPROXY_DEFAULT_QUALITY=82
# IMGPROXY_MAX_WIDTH=2400
# IMGPROXY_ALLOW_UNSIGNED=false
# IMGPROXY_SOURCE_BASE_URL=http://127.0.0.1:3001
# IMGPROXY_FALLBACK_TO_ORIGINAL=true
